{
  "name": "landrive",
  "version": "1.1.0",
  "description": "LANDrive - A lightweight, fast, and privacy-focused peer-to-peer file sharing application for local networks. Share files between devices instantly with zero internet dependency.",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --win --x64",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.landrive.app",
    "productName": "LANDrive",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "public/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "dependencies": {
    "archiver": "^6.0.1",
    "electron-updater": "^6.8.3",
    "express": "^4.18.2",
    "fs-extra": "^11.2.0",
    "mdns-js": "^1.0.1",
    "mime-types": "^2.1.35",
    "multer": "^1.4.5-lts.1",
    "open": "^9.1.0",
    "socket.io": "^4.7.2"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^26.8.1"
  },
  "publish": {
    "provider": "generic",
    "url": "http://your-server-ip:8888/updates"
  }
}
